                    { type: "mcq", question: "البوليمرات الحيوية التي تتكون من أحماض أمينية ترتبط بروابط ببتيدية:", options: ["الأحماض النووية", "البروتينات", "الستيرويدات", "الجليسريدات"], correctIndex: 1, explanation: "البروتينات هي سلاسل من الأحماض الأمينية.", wrongWhy: "الأحماض النووية تتكون من نيوكليوتيدات.", law: "تركيب البروتينات" },
                    { type: "mcq", question: "أحد البروتينات التالية ينقل الأكسجين في الدم:", options: ["الكولاجين", "الهيموجلوبين", "الأنسولين", "الجلوكاجون"], correctIndex: 1, explanation: "الهيموجلوبين هو بروتين النقل الموجود في خلايا الدم الحمراء.", wrongWhy: "الكولاجين بنائي، والأنسولين هرمون تنظيم السكر.", law: "وظائف البروتينات" },
                    { type: "mcq", question: "من السكريات الأحادية:", options: ["السكروز", "الجلوكوز", "السليلوز", "اللاكتوز"], correctIndex: 1, explanation: "الجلوكوز سكر أحادي بسيط يتكون من 6 ذرات كربون.", wrongWhy: "السكروز واللاكتوز سكريات ثنائية، والسليلوز عديد.", law: "تصنيف الكربوهيدرات" },
                    { type: "tf", question: "الرابطة التي تنشأ بين حمضين أمينيين تسمى رابطة ببتيدية.", correct: true, wrongWord: "", correctWord: "", correctedSentence: "", explanation: "الرابطة الببتيدية (مجموعة أميد) هي التي تربط الأحماض الأمينية في البروتين.", law: "الروابط الببتيدية" },
                    { type: "tf", question: "يتكون الحمض النووي DNA من شريط واحد.", correct: false, wrongWord: "شريط واحد", correctWord: "شريطين", correctedSentence: "يتكون الحمض النووي DNA من شريطين مزدوجين.", explanation: "DNA شريط مزدوج، بينما RNA شريط مفرد.", law: "تركيب الأحماض النووية" },
                    { type: "essay", question: "ما هو عامل محفز حيوي يعمل على تسريع التفاعلات داخل الخلايا؟", keywords: ["الانزيم", "الإنزيم"], modelAnswer: "الإنزيم.", explanation: "الإنزيمات هي بروتينات تعمل كمحفزات حيوية فعالة جداً.", law: "وظائف الإنزيمات" }
                ]
            }
        };

        let currentUnitId = null;
        let currentQuestions = [];
        let currentIndex = 0;
        let userProgress = {};
        let currentAnswerSelected = null;

        function startUnit(unitId) {
            if (userProgress[unitId] && userProgress[unitId].completed) {
                const restart = prompt(`لقد أكملت هذه الوحدة (النتيجة: ${calculateScore(unitId)}%).\nهل تريد إعادة الاختبار؟ اكتب 'نعم' للإعادة أو 'لا' لمراجعة أخطائك.`);
                if (restart && restart.trim().toLowerCase() === 'نعم') {
                    // Reset
                } else {
                    showResults(unitId);
                    return;
                }
            }

            currentUnitId = unitId;
            currentQuestions = database[unitId].questions;
            currentIndex = 0;
            userProgress[unitId] = { score: 0, wrongAnswers: [], completed: false };

            document.getElementById('welcome').style.display = 'none';
            document.getElementById('results-container').style.display = 'none';
            document.getElementById('quiz-container').style.display = 'block';
            document.getElementById('unit-title').innerText = database[unitId].title;
            
            loadQuestion();
        }

        function loadQuestion() {
            const q = currentQuestions[currentIndex];
            document.getElementById('current-q-num').innerText = currentIndex + 1;
            document.getElementById('total-q-num').innerText = currentQuestions.length;
            document.getElementById('question-text').innerText = q.question;
            
            const optionsContainer = document.getElementById('options-container');
            optionsContainer.innerHTML = '';
            document.getElementById('feedback').style.display = 'none';
            document.getElementById('submit-btn').style.display = 'block';
            document.getElementById('next-btn').style.display = 'none';
            currentAnswerSelected = null;

            if (q.type === 'mcq') {
                q.options.forEach((opt, index) => {
                    const btn = document.createElement('button');
                    btn.className = 'option-btn';
                    btn.innerText = opt;
                    btn.onclick = () => selectOption(btn, index);
                    optionsContainer.appendChild(btn);
                });
            } else if (q.type === 'tf') {
                ['صح', 'خطأ'].forEach((opt, index) => {
                    const btn = document.createElement('button');
                    btn.className = 'option-btn';
                    btn.innerText = opt;
                    btn.onclick = () => selectOption(btn, index === 0 ? true : false);
                    optionsContainer.appendChild(btn);
                });
            } else if (q.type === 'essay') {
                const textarea = document.createElement('textarea');
                textarea.placeholder = "اكتب إجابتك هنا...";
                textarea.oninput = (e) => { currentAnswerSelected = e.target.value; };
                optionsContainer.appendChild(textarea);
            }
        }

        function selectOption(element, value) {
            const buttons = document.querySelectorAll('.option-btn');
            buttons.forEach(b => b.classList.remove('selected'));
            element.classList.add('selected');
            currentAnswerSelected = value;
        }

        function checkAnswer() {
            if (currentAnswerSelected === null || currentAnswerSelected === '') {
                alert('الرجاء إدخال أو اختيار إجابة.');
                return;
            }

            const q = currentQuestions[currentIndex];
            const feedbackBox = document.getElementById('feedback');
            document.getElementById('submit-btn').style.display = 'none';
            document.getElementById('next-btn').style.display = 'block';

            let isCorrect = false;
            let html = '';

            if (q.type === 'mcq') {
                isCorrect = (currentAnswerSelected === q.correctIndex);
            } else if (q.type === 'tf') {
                isCorrect = (currentAnswerSelected === q.correct);
            } else if (q.type === 'essay') {
                const text = currentAnswerSelected.toLowerCase();
                const matched = q.keywords.filter(kw => text.includes(kw));
                isCorrect = (matched.length > 0); 
            }

            if (isCorrect) {
                userProgress[currentUnitId].score++;
                feedbackBox.className = 'feedback correct';
                html += `<h4>✅ إجابة صحيحة</h4>`;
            } else {
                let wrongEntry = { question: q.question, userAnswer: currentAnswerSelected, qData: q };
                userProgress[currentUnitId].wrongAnswers.push(wrongEntry);
                feedbackBox.className = 'feedback wrong';
                html += `<h4>❌ إجابة خاطئة</h4>`;
            }

            if (q.type === 'tf' && !isCorrect && q.correct === false) {
                html += `<p><strong>الكلمة الخاطئة:</strong> <del>${q.wrongWord}</del> <br>
                         <strong>الكلمة الصحيحة:</strong> <span style="color:var(--success); font-weight:bold;">${q.correctWord}</span><br>
                         <strong>الجملة بعد التصحيح:</strong> ${q.correctedSentence}</p>`;
            }
            if (q.type === 'essay' && !isCorrect) {
                html += `<p><strong>الإجابة النموذجية:</strong> ${q.modelAnswer}</p>`;
            }
            if (q.type === 'mcq' && !isCorrect) {
                html += `<p><strong>الإجابة الصحيحة هي:</strong> ${q.options[q.correctIndex]}</p>`;
                html += `<p><strong>لماذا الخيارات الأخرى خاطئة؟</strong> ${q.wrongWhy}</p>`;
            }

            html += `<p>📖 <strong>التفسير:</strong> ${q.explanation}</p>`;
            html += `<p>📐 <strong>القاعدة:</strong> ${q.law}</p>`;

            feedbackBox.innerHTML = html;
            feedbackBox.style.display = 'block';
            
            document.querySelectorAll('.option-btn, textarea').forEach(el => el.disabled = true);
        }

        function nextQuestion() {
            currentIndex++;
            if (currentIndex < currentQuestions.length) {
                loadQuestion();
            } else {
                userProgress[currentUnitId].completed = true;
                markSidebarCompleted(currentUnitId);
                showResults(currentUnitId);
            }
        }

        function calculateScore(unitId) {
            const total = database[unitId].questions.length;
            const score = userProgress[unitId].score;
            return Math.round((score / total) * 100);
        }

        function showResults(unitId) {
            document.getElementById('quiz-container').style.display = 'none';
            document.getElementById('results-container').style.display = 'block';
            
            document.getElementById('results-title').innerText = `نتيجة ${database[unitId].title}`;
            const percent = calculateScore(unitId);
            document.getElementById('score-text').innerText = `لقد حصلت على ${percent}% (${userProgress[unitId].score} من ${database[unitId].questions.length})`;

            const reviewContainer = document.getElementById('wrong-answers-review');
            reviewContainer.innerHTML = '';

            const wrongArr = userProgress[unitId].wrongAnswers;
            if (wrongArr.length === 0) {
                reviewContainer.innerHTML = `<h3 style="color:var(--success); text-align:center;">ممتاز! لقد أجبت على جميع الأسئلة بشكل صحيح. 🎉</h3>`;
            } else {
                reviewContainer.innerHTML = `<h3 style="color:var(--primary);">مراجعة الأخطاء:</h3>`;
                wrongArr.forEach((err) => {
                    const qData = err.qData;
                    let uAnsStr = err.userAnswer;
                    if (qData.type === 'tf') uAnsStr = (uAnsStr === true ? 'صح' : 'خطأ');
                    if (qData.type === 'mcq') uAnsStr = qData.options[uAnsStr];

                    let div = document.createElement('div');
                    div.className = 'review-card';
                    
                    let html = `<h5>❌ السؤال: ${err.question}</h5>
                                <p><strong>إجابتك:</strong> ${uAnsStr}</p>`;
                    
                    if (qData.type === 'mcq') {
                         html += `<p><strong>الإجابة الصحيحة:</strong> ${qData.options[qData.correctIndex]}</p>`;
                    } else if (qData.type === 'tf') {
                         if(qData.correct === false) {
                            html += `<p><strong>التصحيح:</strong> ${qData.correctedSentence}</p>`;
                         } else {
                            html += `<p><strong>الإجابة الصحيحة هي:</strong> صح</p>`;
                         }
                    } else if (qData.type === 'essay') {
                         html += `<p><strong>الإجابة النموذجية:</strong> ${qData.modelAnswer}</p>`;
                    }
                    html += `<p>📖 <strong>التفسير:</strong> ${qData.explanation}<br>
                             📐 <strong>القاعدة:</strong> ${qData.law}</p>`;
                    
                    div.innerHTML = html;
                    reviewContainer.appendChild(div);
                });
            }
        }

        function returnToMenu() {
            document.getElementById('results-container').style.display = 'none';
            document.getElementById('welcome').style.display = 'block';
        }

        function markSidebarCompleted(unitId) {
            const btns = document.querySelectorAll('.unit-btn');
            btns[unitId - 1].classList.add('completed');
        }
    </script>
</body>
</html>
